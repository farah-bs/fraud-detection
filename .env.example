# ── PostgreSQL ────────────────────────────────────────────────────────────────
PG_HOST_TRAIN=postgres
PG_PORT_TRAIN=5432
PG_DB_TRAIN=social_app
PG_USER_TRAIN=postgres
PG_PASS_TRAIN=changeme

PG_HOST_PROD=postgres
PG_PORT_PROD=5432
PG_DB_PROD=social_app
PG_USER_PROD=postgres
PG_PASS_PROD=changeme

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASS=changeme

# Example pour windows
IMPORT_DIR=C:\Users\user\neo4j\import

# ── Modèle GNN ────────────────────────────────────────────────────────────────
GNN_FEATURE_DIM=8
GNN_HIDDEN_DIM=64
GNN_NUM_LAYERS=3
GNN_DROPOUT=0.3
GNN_LR=0.001
GNN_EPOCHS=100
GNN_BATCH_SIZE=32

# ── Inférence ─────────────────────────────────────────────────────────────────
MODEL_PATH=/app/model/gnn_fraud_detector.pt
FRAUD_THRESHOLD=0.6

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Dataset ───────────────────────────────────────────────────────────────────
DATASET_DIR=/app/data/social_honeypot_dataset

FOLLOW_SAMPLE_RATIO=0.15
RECIP_LEGITIMATE=0.25
RECIP_POLLUTER=0.04
BATCH_SIZE=5000
RANDOM_SEED=42
