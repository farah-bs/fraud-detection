# ── PostgreSQL ────────────────────────────────────────────────────────────────
PG_HOST=postgres
PG_PORT=5432
PG_DB=social_app
PG_USER=postgres
PG_PASS=changeme

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASS=changeme

# ── Modèle GNN ────────────────────────────────────────────────────────────────
GNN_FEATURE_DIM=8
GNN_HIDDEN_DIM=64
GNN_NUM_LAYERS=3
GNN_DROPOUT=0.3
GNN_LR=0.001
GNN_EPOCHS=100
GNN_BATCH_SIZE=32

# ── Inférence ─────────────────────────────────────────────────────────────────
MODEL_PATH=/app/model/gnn_fraud_detector.pt
FRAUD_THRESHOLD=0.6

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
